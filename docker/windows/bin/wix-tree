#!/bin/bash
set -eufo pipefail

#
# Generate wix v3 entry XML trees
#

usage() {
    printf "usage: %s <app> <source-media> <arch>\n" "$0"
}

if [ "$#" != 3 ] || [ -z "$1" ] || [ -z "$2" ] || [ -z "$3" ]; then
    usage
    exit 1
fi

DIR_ID=0
COMPONENT_ID=0

set -x

wix-entry() {
    local dir="$1"
    local dir_basename="$(basename "$dir")"
    local f=''
    local win64='Win64="yes"'

    if [ "$bitness" != '64' ]; then
        win64=''
    fi

    for f in $(find "$dir" -maxdepth 1 -print | sort); do
        f="${f#./}"

        if [ "$f" = '.' ]; then
            continue
        fi

        local b="$(basename "$f")"

        if [ -d "$f" ]; then
            printf "<Directory Id=\"%s\" Name=\"%s\">" "Dir$DIR_ID" "$b"
            DIR_ID=$((DIR_ID + 1))

            cd "$f"

            wix-entry .

            cd ..

            printf "</Directory>"
        elif [ -f "$f" ]; then
            r="$(realpath "$b")"
            printf "<Component Id=\"%s\" Guid=\"%s\">" "Component$COMPONENT_ID" "$(uuidgen)"
            printf "<File Id=\"%s\" Name=\"%s\" Source=\"%s\" DiskId=\"1\" KeyPath=\"yes\" %s />" "File$b" "$b" "$b" "$win64"
            printf "</Component>"
            COMPONENT_ID=$((COMPONENT + 1))
        else
            echo "error: ${ROCKHOPPER_IMAGE}: unsupported file system file type for path: ${f}"
        fi
    done
}

bitness='32'
program_files_folder='ProgramFilesFolder'

if [[ "$3" = "*64*" ]; then
    bitness='64'
    program_files_folder='ProgramFiles64Folder'
fi

printf "<Directory Id=\"TARGETDIR\" Name=\"SourceDir\"><Directory Id=\"%s\" Name=\"PFiles\"><Directory Id=\"INSTALLLOCATION\" Name=\"$2\">" "$program_files_folder"

wix-entry "$1"

printf "</Directory></Directory></Directory>"
printf "<Feature Id=\"Complete\" Level=\"1\">"

for COMPONENT_ENTRY in "${COMPONENT_ENTRIES[@]}"; do
    printf "<ComponentRef Id=\"$COMPONENT_ENTRY\" />"
done

printf "</Feature>\n"
