#!/bin/bash
unset IFS
set -euo pipefail

rocklet_log_level="${rocklet_log_level:-info}"
rocklet_image="${rocklet_image:-unknown image}"
rocklet_mount_path="${rocklet_mount_path:-/mnt/rockhopper}"
rocklet_name="${rocklet_name:-}"
rocklet_manufacturer="${rocklet_manufacturer:-}"
rocklet_version="${rocklet_version:-}"
rocklet_rev="${rocklet_rev:-}"
rocklet_summary="${rocklet_summary:-}"
rocklet_copyright="${rocklet_copyright:-}"
rocklet_license="${rocklet_license:-}"
rocklet_templates="${rocklet_templates:-"$HOME/templates"}"
rocklet_cache="${rocklet_cache:-"$rocklet_mount_path/.rockhopper"}"
rocklet_artifact="${rocklet_artifact:-"$rocklet_cache/artifacts/windows"}"
rocklet_msi_build="${rocklet_msi_build:-/tmp/windows}"

# https://learn.microsoft.com/en-us/windows/win32/msi/using-an-upgradecode
rocklet_msi_upgrade_code="${rocklet_msi_upgrade_code:-}"

# https://learn.microsoft.com/en-us/openspecs/office_standards/ms-oe376/6c085406-a698-4e12-9d4d-c3b0ee3dbc4a
rocklet_msi_lcid="${rocklet_msi_lcid:-1033}"

# https://learn.microsoft.com/en-us/windows/win32/intl/code-page-identifiers
rocklet_msi_codepage="${rocklet_msi_codepage:-1252}"

rocklet_os_arch="${rocklet_os_arch:-"$(mename)"}"

# Forward rockhopper environment variables to Jinja
for K in $(compgen -v | grep '^rocklet_'); do
    export "$K"
done

usage() {
    printf "Usage: %s [<OPTION>]\n" "$0"
    printf "\n"
    printf -- "--debug -d\tIncrease logging\n"
    printf -- "--quiet -q\tReduce logging\n"
    printf -- "--help -h\tShow usage menu\n"
    printf -- "--version -V\tShow version banner\n"
}

ROCKHOPPER_VERSION='0.0.18'
ROCKHOPPER_REV='1'

banner() {
    echo "$0 $ROCKHOPPER_VERSION-$ROCKHOPPER_REV"
}

while [ "$#" -ge 1 ]; do
    case "$1" in
    '--debug' | '-d')
        shift
        rocklet_log_level='debug'
        ;;
    '--quiet' | 'q')
        shift
        rocklet_log_level='quiet'
        ;;
    '--help' | '-h')
        usage
        exit
        ;;
    '--version' | '-V')
        banner
        exit
        ;;
    *)
        usage
        exit 1
        ;;
    esac
done

if [ "$rocklet_log_level" = 'debug' ]; then
    env | grep '^rocklet_' | sort
    set -x
fi

validate() {
    required_env_vars=(
        rocklet_artifact
        rocklet_cache
        rocklet_image
        rocklet_log_level
        rocklet_mount_path
        rocklet_manufacturer
        rocklet_msi_codepage
        rocklet_msi_build
        rocklet_msi_upgrade_code
        rocklet_name
        rocklet_os_arch
        rocklet_summary
        rocklet_templates
        rocklet_version
    )

    for required_env_var in "${required_env_vars[@]}"; do
        eval "required_env_val=\$$required_env_var"

        if [ -z "$required_env_val" ]; then
            echo "error: ${rocklet_image} blank/missing env var: ${required_env_var}"
            exit 1
        fi
    done
}

clean() {
    rm -rf "$rocklet_msi_build"
}

validate
clean

source_media="$rocklet_cache/source-media"
mkdir -p "$source_media"

mkdir -p "$rocklet_msi_build"

if [ -n "$rocklet_copyright" ] || [ -n "$rocklet_license" ]; then
    LICENSE="$rocklet_msi_build/LICENSE.txt"
    rsubst --strict "$rocklet_templates/LICENSE.txt.j2" >"$LICENSE"

    if [ "$rocklet_log_level" = 'debug' ]; then
        echo 'LICENSE.txt:'
        cat "$LICENSE"
    fi
fi

find "$source_media" -type f -exec cp "{}" "$rocklet_msi_build" \;

cd "$rocklet_msi_build"

msi_files="$(wix-tree . "$rocklet_name" "$rocklet_os_arch")"

if [ -z "$msi_files" ]; then
    echo 'error: blank source media list' >&2
    exit 1
fi

export msi_files

PRODUCT='Product.wxs'
rsubst --strict "$rocklet_templates/Product.wxs.j2" >"$PRODUCT"

if [ "$rocklet_log_level" = 'debug' ]; then
    echo 'Product.wxs:'
    cat "$PRODUCT"
fi

artifact="${rocklet_name}-${rocklet_version}"

if [ -n "$rocklet_rev" ]; then
    artifact="${artifact}.${rocklet_rev}"
fi

artifact="${artifact}-${rocklet_os_arch}.msi"

mkdir -p "$rocklet_artifact"
wixl -v -o "$rocklet_artifact/$artifact" -a "$rocklet_os_arch" "$PRODUCT"

clean
